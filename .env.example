BOT_TOKEN=your_bot_token_here
OPENROUTER_API_KEY=sk-or-...
ENCRYPTION_KEY=your_32_byte_encryption_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Model Access Control (key required to change AI models)
# Default: BlackCatsMeow - Change this to your preferred secret key
MODEL_ACCESS_KEY=BlackCatsMeow

# Campaign Management Access Key (required to add/update/delete preset campaigns)
# Default: CampaignAdmin2024 - Change this to your preferred secret key
CAMPAIGN_ACCESS_KEY=CampaignAdmin2024


AVAILABLE_MODELS="x-ai/grok-4.1-fast,z-ai/glm-4.7-flash,openai/gpt-oss-120b,meta-llama/llama-4-scout,meta-llama/llama-3.3-70b-instruct:free,meta-llama/llama-3.3-70b-instruct:free,mistralai/mistral-small-3.1:free,nvidia/nemotron-3-nano-30b-a3b:free"